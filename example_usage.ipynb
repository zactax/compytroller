   "source": [
    "\"\"\"\n",
    "Full end-to-end usage demonstration of the Compytroller client.\n",
    "\n",
    "This script:\n",
    "- Instantiates ComptrollerClient\n",
    "- Calls every major resource class\n",
    "- Fetches live data (requires a real APP_TOKEN)\n",
    "- Prints sample records for visual verification\n",
    "\"\"\"\n",
    "\n",
    "import pandas as pd\n",
    "from src.compytroller.client import ComptrollerClient"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "d8cce4a4",
   "metadata": {},
   "outputs": [],
   "source": [
    "def print_sample(label, results, n=3):\n",
    "    \"\"\"Pretty print the first few results.\"\"\"\n",
    "    print(f\"\\n=== {label} (showing {min(n, len(results))} results) ===\")\n",
    "    if not results:\n",
    "        print(\"No results returned.\")\n",
    "        return\n",
    "    for row in results[:n]:\n",
    "        print(row)"
   ]
  },
